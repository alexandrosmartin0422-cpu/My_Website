# Copy this file to ".env.local" and fill in real values.
# .env.local is git-ignored, so your credentials stay private.

# --- SMTP (email sending) ---
# Defaults below work for Gmail. For Gmail you MUST use an "App Password"
# (https://myaccount.google.com/apppasswords), NOT your normal password.
# App Passwords require 2-Step Verification to be enabled on the account.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-16-char-app-password
